{
  "expo": {
    "name": "VJ Billing",
    "slug": "vjbilling",
    "scheme": "vjbilling",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF3E0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vjbilling.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF3E0"
      },
      "package": "com.vjbilling.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a9e6e529-2f3b-429d-b0d6-8ecbfd68443f"
      }
    }
  }
}
